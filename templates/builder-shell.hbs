<section class="swf-builder-shell__body">
  <p>
    Safe stage-1 builder shell for GM preview workflows.
    This window is read-only and does not create or mutate Item, Actor, or Journal documents.
  </p>

  <ul class="swf-builder-shell__status">
    <li>Schema: v{{shell.schemaVersion}}</li>
    <li>Mode: {{shell.mode}}</li>
    <li>Source: {{shell.source}}</li>
    <li>Session: <code>{{shell.sessionId}}</code></li>
  </ul>

  <nav class="swf-builder-shell__tabs" aria-label="Builder surfaces">
    {{#each surfaces}}
      <button
        type="button"
        class="swf-builder-shell__tab {{#if this.isActive}}is-active{{/if}}"
        data-builder-surface="{{this.key}}"
      >
        {{this.label}}
      </button>
    {{/each}}
  </nav>

  {{#if activePreview}}
    <section class="swf-builder-shell__panel">
      <h3>{{activePreview.label}} Preview (Read-Only)</h3>
      <ul class="swf-builder-shell__status">
        <li>Status: {{activePreview.status}}</li>
        <li>Document: {{activePreview.preview.documentName}}</li>
        <li>Name: {{activePreview.preview.name}}</li>
        <li>Type Hint: {{activePreview.preview.typeHint}}</li>
        <li>Read-Only: {{#if activePreview.readOnly}}yes{{else}}no{{/if}}</li>
        <li>Materialization: {{#if activePreview.nonMaterialized}}deferred{{else}}active{{/if}}</li>
      </ul>

      <h4>Summary</h4>
      <p>{{activePreview.preview.summary}}</p>

      {{#if activePreview.preview.roleLabel}}
        <h4>Actor Authoring Structure</h4>
        <ul class="swf-builder-shell__status">
          <li>Role Label: {{activePreview.preview.roleLabel}}</li>
          <li>Concept: {{activePreview.preview.concept}}</li>
        </ul>

        <div class="swf-builder-shell__cluster-grid">
          <section class="swf-builder-shell__cluster">
            <h5>Identity Cluster</h5>
            <ul class="swf-builder-shell__status">
              <li>Ancestry: {{activePreview.preview.identity.ancestry}}</li>
              <li>Alignment: {{activePreview.preview.identity.alignment}}</li>
              <li>Disposition: {{activePreview.preview.identity.disposition}}</li>
            </ul>
          </section>

          <section class="swf-builder-shell__cluster">
            <h5>Classification Cluster</h5>
            <ul class="swf-builder-shell__status">
              <li>Actor Path: {{activePreview.preview.classification.actorPath}}</li>
              <li>Grouping: {{activePreview.preview.classification.grouping}}</li>
              <li>Encounter Role: {{activePreview.preview.classification.encounterRole}}</li>
            </ul>
          </section>
        </div>

        <h5>Preview Metadata</h5>
        <ul class="swf-builder-shell__status">
          <li>Schema: v{{activePreview.preview.previewMeta.schemaVersion}}</li>
          <li>Mode: {{activePreview.preview.previewMeta.mode}}</li>
          <li>Materialization: {{activePreview.preview.previewMeta.materialization}}</li>
        </ul>
        <ul class="swf-builder-shell__status">
          {{#each activePreview.preview.previewMeta.integrationNotes}}
            <li>{{this}}</li>
          {{/each}}
        </ul>
      {{/if}}

      <h4>Linked References (Shared Preview Model)</h4>
      {{#if referenceRows.length}}
        <ul class="swf-builder-shell__reference-list">
          {{#each referenceRows}}
            <li class="swf-builder-shell__reference-row">
              <div class="swf-builder-shell__reference-title">{{this.title}}</div>
              {{#if this.detailText}}
                <div class="swf-builder-shell__reference-detail">{{this.detailText}}</div>
              {{/if}}
            </li>
          {{/each}}
        </ul>
      {{else}}
        <p class="swf-builder-shell__empty">No linked references are defined for this preview.</p>
      {{/if}}

      <h4>Notes</h4>
      <ul class="swf-builder-shell__status">
        {{#each activePreview.preview.notes}}
          <li>{{this}}</li>
        {{/each}}
      </ul>

      <h4>Shared Preview Payload</h4>
      <pre class="swf-builder-shell__code">{{activePreviewJson}}</pre>
    </section>
  {{else}}
    <p class="swf-builder-shell__empty">No active preview surface is available.</p>
  {{/if}}

  <h4>Current Assumptions</h4>
  <ul class="swf-builder-shell__status">
    {{#each assumptions}}
      <li>{{this}}</li>
    {{/each}}
  </ul>
</section>
