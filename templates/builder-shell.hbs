<section class="swf-builder-shell__body">
  <p>
    Safe stage-1 builder shell for GM preview workflows.
    Actor lane includes one controlled npc-only create action. Item lane includes one controlled feat-only create action. Journal lane includes one controlled create action.
  </p>

  <ul class="swf-builder-shell__status">
    <li>Schema: v{{shell.schemaVersion}}</li>
    <li>Mode: {{shell.mode}}</li>
    <li>Source: {{shell.source}}</li>
    <li>Session: <code>{{shell.sessionId}}</code></li>
  </ul>
  <button type="button" class="swf-builder-shell__action" data-action="reset-workspace-state">
    Reset Builder Workspace State
  </button>

  <nav class="swf-builder-shell__tabs" aria-label="Builder surfaces">
    {{#each surfaces}}
      <button
        type="button"
        class="swf-builder-shell__tab {{#if this.isActive}}is-active{{/if}}"
        data-builder-surface="{{this.key}}"
      >
        {{this.label}}
      </button>
    {{/each}}
  </nav>

  {{#if activePreview}}
    <section class="swf-builder-shell__panel">
      <h3>{{activePreview.label}} Preview (Read-Only)</h3>
      <ul class="swf-builder-shell__status">
        <li>Status: {{activePreview.status}}</li>
        <li>Document: {{activePreview.preview.documentName}}</li>
        <li>Name: {{activePreview.preview.name}}</li>
        <li>Type Hint: {{activePreview.preview.typeHint}}</li>
        <li>Read-Only: {{#if selectedJournalPreset}}mostly (tiny Journal draft fields are editable){{else}}{{#if activePreview.readOnly}}yes{{else}}no{{/if}}{{/if}}</li>
        <li>Materialization: {{#if activePreview.nonMaterialized}}deferred{{else}}active{{/if}}</li>
        <li>Lane Draft: <strong>{{activeLaneDraftStatus}}</strong></li>
      </ul>

      <h4>Summary</h4>
      <p>{{activePreview.preview.summary}}</p>

      {{#if sampleOptions.length}}
        <h4>Sample Definition</h4>
        <label>
          Sample
          <select data-action="select-sample" data-sample-surface="{{activeSurface.key}}">
            {{#each sampleOptions}}
              <option value="{{this.key}}" {{#if this.isSelected}}selected{{/if}}>{{this.label}}</option>
            {{/each}}
          </select>
        </label>
        {{#if selectedSample}}
          <p class="swf-builder-shell__status-note">
            <strong>{{selectedSample.key}}:</strong> {{selectedSample.description}}
          </p>
        {{/if}}
        {{#if activeSampleState}}
          <ul class="swf-builder-shell__status">
            <li>Active Sample: <strong>{{activeSampleState.activeSampleLabel}}</strong> (<code>{{activeSampleState.activeSampleKey}}</code>)</li>
            <li>State Origin: <strong>{{activeSampleState.activeStateOrigin}}</strong></li>
            <li>{{activeSampleState.activeStateOriginLabel}}</li>
          </ul>
        {{/if}}
      {{/if}}

      {{#if itemValidation}}
        <h4>Item Materialization (Controlled Slice)</h4>
        <section class="swf-builder-shell__inspection">
          <h5>Item Validation</h5>
          <p class="swf-builder-shell__status-note swf-builder-shell__status-note--{{#if itemValidation.ok}}success{{else}}error{{/if}}">
            <strong>{{itemValidation.status.label}}:</strong>
            {{itemValidation.status.summary}}
          </p>
          {{#if itemValidation.errors.length}}
            <h6>Errors (creation blocked)</h6>
            <ul class="swf-builder-shell__status">
              {{#each itemValidation.errors}}
                <li>{{this}}</li>
              {{/each}}
            </ul>
          {{/if}}
          {{#if itemValidation.warnings.length}}
            <h6>Warnings</h6>
            <ul class="swf-builder-shell__status">
              {{#each itemValidation.warnings}}
                <li>{{this}}</li>
              {{/each}}
            </ul>
          {{/if}}
        </section>
        {{#if itemCreateIntentSummary}}
          <section class="swf-builder-shell__inspection">
            <h5>Item Pipeline Stage: Create Intent Summary</h5>
            <ul class="swf-builder-shell__status">
              <li>Path: <code>{{itemCreateIntentSummary.path}}</code></li>
              <li>Supported Item Type: {{itemCreateIntentSummary.supportedItemType}}</li>
              <li>Name: {{itemCreateIntentSummary.name}}</li>
              <li>Type: {{itemCreateIntentSummary.type}}</li>
              <li>Feat Subtype: {{itemCreateIntentSummary.featSubtype}}</li>
              <li>Description Length: {{itemCreateIntentSummary.descriptionLength}}</li>
              <li>Requirements: {{itemCreateIntentSummary.requirements}}</li>
            </ul>
            <h6>Deferred Clusters</h6>
            <ul class="swf-builder-shell__status">
              {{#each itemCreateIntentSummary.deferredClusters}}
                <li>{{this}}</li>
              {{/each}}
            </ul>
          </section>
        {{/if}}
        <p>Creates one world Item (type feat) from the current Item preview using minimal v13-safe fields.</p>
        <button
          type="button"
          class="swf-builder-shell__action"
          data-action="create-item"
          {{#unless canCreateItem}}disabled title="Item creation is blocked until validation errors are resolved."{{/unless}}
        >
          Create Item (Feat Path)
        </button>
        {{#if itemCreateInspection}}
          <section class="swf-builder-shell__inspection">
            <h5>Item Pipeline Stage: Post-Creation Inspection</h5>
            <p
              class="swf-builder-shell__status-note swf-builder-shell__status-note--{{#if itemCreateInspection.status.ok}}success{{else}}error{{/if}}"
            >
              <strong>{{itemCreateInspection.status.label}}:</strong>
              {{itemCreateInspection.status.message}}
            </p>
            {{#if itemCreateInspection.createdItem}}
              <ul class="swf-builder-shell__status">
                <li>Name: {{itemCreateInspection.createdItem.name}}</li>
                <li>Type: {{itemCreateInspection.createdItem.type}}</li>
                <li>ID: <code>{{itemCreateInspection.createdItem.id}}</code></li>
                {{#if itemCreateInspection.createdItem.uuid}}
                  <li>UUID: <code>{{itemCreateInspection.createdItem.uuid}}</code></li>
                {{/if}}
              </ul>
              {{#if canOpenCreatedItem}}
                <button type="button" class="swf-builder-shell__action" data-action="open-created-item">
                  Open Created Item
                </button>
              {{/if}}
            {{/if}}
            <h6>Materialized Clusters</h6>
            <ul class="swf-builder-shell__status">
              {{#each itemCreateInspection.materializedClusters}}
                <li>{{this}}</li>
              {{/each}}
            </ul>
            <h6>Inspection Trace Summary</h6>
            <ul class="swf-builder-shell__status">
              <li>Attempted comparisons: {{itemCreateInspection.traceSummary.attempted}}</li>
              <li>Materialized: {{itemCreateInspection.traceSummary.materialized}}</li>
              <li>Needs review: {{itemCreateInspection.traceSummary.reviewNeeded}}</li>
              <li>Deferred inspection: {{itemCreateInspection.traceSummary.deferredInspection}}</li>
            </ul>
            <h6>Deferred Clusters</h6>
            <ul class="swf-builder-shell__status">
              {{#each itemCreateInspection.deferredClusters}}
                <li>{{this}}</li>
              {{/each}}
            </ul>
            <h6>Cluster Comparison (Preview → Requested → Actual)</h6>
            <ul class="swf-builder-shell__status">
              {{#each itemCreateInspection.clusterComparisons}}
                <li>
                  <strong>{{this.label}}</strong> [{{this.status}}]:
                  preview={{this.preview}} |
                  requested={{this.requested}} |
                  actual={{this.actual}}
                </li>
              {{/each}}
            </ul>
            <h6>Preview → Created Mapping</h6>
            <ul class="swf-builder-shell__status">
              {{#each itemCreateInspection.fieldMapping}}
                <li>
                  <strong>{{this.key}}</strong> [{{this.status}}]:
                  preview={{this.preview}} |
                  requested={{this.requested}} |
                  actual={{this.actual}}
                </li>
              {{/each}}
            </ul>
            {{#if itemCreateInspection.warnings.length}}
              <h6>Warnings / Review Notes</h6>
              <ul class="swf-builder-shell__status">
                {{#each itemCreateInspection.warnings}}
                  <li>{{this}}</li>
                {{/each}}
              </ul>
            {{/if}}
            {{#if itemCreateInspection.notes.length}}
              <h6>Notes</h6>
              <ul class="swf-builder-shell__status">
                {{#each itemCreateInspection.notes}}
                  <li>{{this}}</li>
                {{/each}}
              </ul>
            {{/if}}
          </section>
        {{/if}}
      {{/if}}

      {{#if actorValidation}}
        <h4>Actor Materialization (Controlled Slice)</h4>
        <section class="swf-builder-shell__inspection">
          <h5>Actor Validation</h5>
          <p class="swf-builder-shell__status-note swf-builder-shell__status-note--{{#if actorValidation.ok}}success{{else}}error{{/if}}">
            <strong>{{actorValidation.status.label}}:</strong>
            {{actorValidation.status.summary}}
          </p>
          {{#if actorValidation.errors.length}}
            <h6>Errors (creation blocked)</h6>
            <ul class="swf-builder-shell__status">
              {{#each actorValidation.errors}}
                <li>{{this}}</li>
              {{/each}}
            </ul>
          {{/if}}
          {{#if actorValidation.warnings.length}}
            <h6>Warnings</h6>
            <ul class="swf-builder-shell__status">
              {{#each actorValidation.warnings}}
                <li>{{this}}</li>
              {{/each}}
            </ul>
          {{/if}}
        </section>
        {{#if actorCreateIntentSummary}}
          <section class="swf-builder-shell__inspection">
            <h5>Actor Pipeline Stage: Create Intent Summary</h5>
            <ul class="swf-builder-shell__status">
              <li>Path: <code>{{actorCreateIntentSummary.path}}</code></li>
              <li>Supported Actor Type: {{actorCreateIntentSummary.supportedActorType}}</li>
              <li>Name: {{actorCreateIntentSummary.name}}</li>
              <li>Type: {{actorCreateIntentSummary.type}}</li>
              <li>Image: <code>{{actorCreateIntentSummary.img}}</code></li>
              <li>Retained Summary: {{actorCreateIntentSummary.retainedDraftSummary}}</li>
              <li>Retained Role Label: {{actorCreateIntentSummary.retainedDraftRoleLabel}}</li>
              <li>Retained Concept: {{actorCreateIntentSummary.retainedDraftConcept}}</li>
            </ul>
            <h6>Deferred Clusters</h6>
            <ul class="swf-builder-shell__status">
              {{#each actorCreateIntentSummary.deferredClusters}}
                <li>{{this}}</li>
              {{/each}}
            </ul>
          </section>
        {{/if}}
        <p>Creates one world Actor (type npc) from the current Actor preview using minimal v13-safe fields.</p>
        <button
          type="button"
          class="swf-builder-shell__action"
          data-action="create-actor"
          {{#unless canCreateActor}}disabled title="Actor creation is blocked until validation errors are resolved."{{/unless}}
        >
          Create Actor (NPC Path)
        </button>
        {{#if actorCreateInspection}}
          <section class="swf-builder-shell__inspection">
            <h5>Actor Pipeline Stage: Post-Creation Inspection</h5>
            <p
              class="swf-builder-shell__status-note swf-builder-shell__status-note--{{#if actorCreateInspection.status.ok}}success{{else}}error{{/if}}"
            >
              <strong>{{actorCreateInspection.status.label}}:</strong>
              {{actorCreateInspection.status.message}}
            </p>
            {{#if actorCreateInspection.createdActor}}
              <ul class="swf-builder-shell__status">
                <li>Name: {{actorCreateInspection.createdActor.name}}</li>
                <li>Type: {{actorCreateInspection.createdActor.type}}</li>
                <li>Image: <code>{{actorCreateInspection.createdActor.img}}</code></li>
                <li>Folder: {{actorCreateInspection.createdActor.folder}}</li>
                <li>ID: <code>{{actorCreateInspection.createdActor.id}}</code></li>
                {{#if actorCreateInspection.createdActor.uuid}}
                  <li>UUID: <code>{{actorCreateInspection.createdActor.uuid}}</code></li>
                {{/if}}
              </ul>
              {{#if canOpenCreatedActor}}
                <button type="button" class="swf-builder-shell__action" data-action="open-created-actor">
                  Open Created Actor
                </button>
              {{/if}}
            {{/if}}
            <h6>Materialized Clusters</h6>
            <ul class="swf-builder-shell__status">
              {{#each actorCreateInspection.materializedClusters}}
                <li>{{this}}</li>
              {{/each}}
            </ul>
            <h6>Inspection Trace Summary</h6>
            <ul class="swf-builder-shell__status">
              <li>Attempted comparisons: {{actorCreateInspection.traceSummary.attempted}}</li>
              <li>Materialized: {{actorCreateInspection.traceSummary.materialized}}</li>
              <li>Needs review: {{actorCreateInspection.traceSummary.reviewNeeded}}</li>
              <li>Deferred inspection: {{actorCreateInspection.traceSummary.deferredInspection}}</li>
            </ul>
            <h6>Deferred Clusters</h6>
            <ul class="swf-builder-shell__status">
              {{#each actorCreateInspection.deferredClusters}}
                <li>{{this}}</li>
              {{/each}}
            </ul>
            <h6>Cluster Comparison (Preview → Requested → Actual)</h6>
            <ul class="swf-builder-shell__status">
              {{#each actorCreateInspection.clusterComparisons}}
                <li>
                  <strong>{{this.label}}</strong> [{{this.status}}]:
                  preview={{this.preview}} |
                  requested={{this.requested}} |
                  actual={{this.actual}}
                </li>
              {{/each}}
            </ul>
            <h6>Allowlisted Reconciliation (Normalized Draft ↔ Created Actor)</h6>
            <ul class="swf-builder-shell__status">
              {{#each actorCreateInspection.inspectionRows}}
                <li>
                  <strong>{{this.label}}</strong> [{{this.outcome}}]:
                  expected={{this.expected}} |
                  actual={{this.actual}}
                </li>
              {{/each}}
            </ul>
            <h6>Preview → Created Mapping</h6>
            <ul class="swf-builder-shell__status">
              {{#each actorCreateInspection.fieldMapping}}
                <li>
                  <strong>{{this.key}}</strong> [{{this.status}}]:
                  preview={{this.preview}} |
                  requested={{this.requested}} |
                  actual={{this.actual}}
                </li>
              {{/each}}
            </ul>
            {{#if actorCreateInspection.warnings.length}}
              <h6>Warnings / Review Notes</h6>
              <ul class="swf-builder-shell__status">
                {{#each actorCreateInspection.warnings}}
                  <li>{{this}}</li>
                {{/each}}
              </ul>
            {{/if}}
            {{#if actorCreateInspection.notes.length}}
              <h6>Notes</h6>
              <ul class="swf-builder-shell__status">
                {{#each actorCreateInspection.notes}}
                  <li>{{this}}</li>
                {{/each}}
              </ul>
            {{/if}}
          </section>
        {{/if}}
      {{/if}}

      {{#if journalSummaryDetailsFrame}}
        <section class="swf-builder-shell__inspection">
          <h5>{{journalSummaryDetailsFrame.frameTitle}}</h5>
          <ul class="swf-builder-shell__status">
            <li><strong>{{journalSummaryDetailsFrame.identityLabel}}:</strong> {{journalSummaryDetailsFrame.identityValue}}</li>
            <li><strong>{{journalSummaryDetailsFrame.summaryLabel}}:</strong> {{journalSummaryDetailsFrame.summaryValue}}</li>
          </ul>
          <h6>{{journalSummaryDetailsFrame.detailsLabel}}</h6>
          {{#if journalSummaryDetailsFrame.detailRows.length}}
            <ul class="swf-builder-shell__status">
              {{#each journalSummaryDetailsFrame.detailRows}}
                <li><strong>{{this.label}}:</strong> {{this.value}}</li>
              {{/each}}
            </ul>
          {{else}}
            <p class="swf-builder-shell__empty">{{journalSummaryDetailsFrame.detailsEmptyText}}</p>
          {{/if}}
        </section>
      {{/if}}

      {{#if selectedJournalPreset}}
        <h4>Journal Preset</h4>
        <label>
          Preset
          <select data-action="select-journal-preset">
            {{#each journalPresetOptions}}
              <option value="{{this.key}}" {{#if this.isSelected}}selected{{/if}}>{{this.label}}</option>
            {{/each}}
          </select>
        </label>
        <p class="swf-builder-shell__status-note">
          Preset changes and Reset Draft both restore preset-derived defaults for this Journal lane.
        </p>
        <ul class="swf-builder-shell__status">
          <li>Preset Key: <code>{{selectedJournalPreset.key}}</code></li>
          <li>Draft Status: <strong>{{#if isJournalDraftDirty}}Modified{{else}}Clean{{/if}}</strong></li>
          <li>{{selectedJournalPreset.description}}</li>
          <li>Overview Page: {{selectedJournalPreset.overviewPageName}}</li>
          <li>Details Page: {{selectedJournalPreset.detailsPageName}}</li>
          <li>Reference Page: {{selectedJournalPreset.referencePageName}}</li>
          <li>Reference Block Title: {{selectedJournalPreset.referenceBlockTitle}}</li>
          <li>Reference Emphasis: {{selectedJournalPreset.referenceBlockSummary}}</li>
          </ul>
        {{#if journalSectionPlan}}
          <h5>Preset Section Structure</h5>
          <ul class="swf-builder-shell__status">
            {{#each journalSectionPlan}}
              <li>
                {{this.order}}. {{this.label}} → page <code>{{this.pageName}}</code>
                {{#if this.conditional}}({{#if this.included}}included{{else}}omitted when empty{{/if}}){{/if}}
                {{#if this.intentNote}} — {{this.intentNote}}{{/if}}
              </li>
            {{/each}}
          </ul>
        {{/if}}
        {{#if journalDraft}}
          <h4>Journal Draft Inputs (Ephemeral)</h4>
          <p>
            Preset switching and Reset Draft restore these fields to preset-derived defaults for predictable behavior in this conservative slice.
          </p>
          <button
            type="button"
            class="swf-builder-shell__action"
            data-action="reset-journal-draft"
            {{#unless isJournalDraftDirty}}disabled title="Draft already matches preset defaults."{{/unless}}
          >
            Reset Draft to Preset Defaults
          </button>
          <div class="swf-builder-shell__draft-grid">
            <label>
              Name
              <input
                type="text"
                data-journal-draft-field="name"
                value="{{journalDraft.name}}"
                placeholder="Journal name"
              />
            </label>
            <label>
              Summary
              <input
                type="text"
                data-journal-draft-field="summary"
                value="{{journalDraft.summary}}"
                placeholder="One-line summary used in overview content"
              />
            </label>
            <label>
              Notes / Details (one line per bullet)
              <textarea
                data-journal-draft-field="notesText"
                rows="5"
                placeholder="Each non-empty line becomes one details bullet"
              >{{journalDraft.notesText}}</textarea>
            </label>
          </div>
        {{/if}}
      {{/if}}

      {{#if canCreateJournal}}
        <h4>Journal Materialization (Controlled Slice)</h4>
      {{else}}
        {{#if selectedJournalPreset}}
          <h4>Journal Materialization (Controlled Slice)</h4>
        {{/if}}
      {{/if}}
      {{#if selectedJournalPreset}}
        <section class="swf-builder-shell__inspection">
          <h5>Journal Draft Validation</h5>
          <p
            class="swf-builder-shell__status-note swf-builder-shell__status-note--{{#if journalValidation.ok}}success{{else}}error{{/if}}"
          >
            <strong>{{journalValidation.status.label}}:</strong>
            {{journalValidation.status.summary}}
          </p>
          {{#if journalValidation.errors.length}}
            <h6>Errors (creation blocked)</h6>
            <ul class="swf-builder-shell__status">
              {{#each journalValidation.errors}}
                <li>{{this}}</li>
              {{/each}}
            </ul>
          {{/if}}
          {{#if journalValidation.warnings.length}}
            <h6>Warnings</h6>
            <ul class="swf-builder-shell__status">
              {{#each journalValidation.warnings}}
                <li>{{this}}</li>
              {{/each}}
            </ul>
          {{/if}}
        </section>
        {{#if journalCreateIntentSummary}}
          <section class="swf-builder-shell__inspection">
            <h5>Journal Pipeline Stage: Create Intent Summary</h5>
            <p class="swf-builder-shell__status-note">
              Exact normalized create intent derived from the current Journal preview/draft state.
            </p>
            <ul class="swf-builder-shell__status">
              <li>Preset: <code>{{journalCreateIntentSummary.presetKey}}</code> ({{journalCreateIntentSummary.presetLabel}})</li>
              <li>Name: {{journalCreateIntentSummary.name}}</li>
              <li>Requested Pages: {{journalCreateIntentSummary.pageCount}}</li>
              <li>Frame Summary Label: {{journalCreateIntentSummary.summaryDetailsFrame.title}}</li>
              <li>Frame Identity Label: {{journalCreateIntentSummary.summaryDetailsFrame.identityLabel}}</li>
              <li>Frame Details Label: {{journalCreateIntentSummary.summaryDetailsFrame.detailsLabel}}</li>
              <li>Reference Emphasis Key: <code>{{journalCreateIntentSummary.referenceEmphasis.presetKey}}</code></li>
              <li>Reference Emphasis Primary Label: {{journalCreateIntentSummary.referenceEmphasis.primaryGroupLabel}}</li>
              <li>Reference Emphasis Secondary Label: {{journalCreateIntentSummary.referenceEmphasis.secondaryGroupLabel}}</li>
              <li>Details Page Included: {{#if journalCreateIntentSummary.includesDetailsPage}}yes{{else}}no{{/if}}</li>
              <li>Deferred References Page Included: {{#if journalCreateIntentSummary.includesDeferredReferencesPage}}yes{{else}}no{{/if}}</li>
            </ul>
            {{#if journalCreateIntentSummary.referenceEmphasis.note}}
              <p class="swf-builder-shell__status-note">{{journalCreateIntentSummary.referenceEmphasis.note}}</p>
            {{/if}}
            {{#if journalCreateIntentSummary.sectionRows.length}}
              <h6>Preset Section Plan</h6>
              <ul class="swf-builder-shell__status">
                {{#each journalCreateIntentSummary.sectionRows}}
                  <li>{{this.order}}. {{this.label}} → {{this.pageName}} ({{#if this.included}}included{{else}}omitted{{/if}}){{#if this.intentNote}} — {{this.intentNote}}{{/if}}</li>
                {{/each}}
              </ul>
            {{/if}}
            {{#if journalCreateIntentSummary.pageRows.length}}
              <h6>Requested Page Names</h6>
              <ul class="swf-builder-shell__status">
                {{#each journalCreateIntentSummary.pageRows}}
                  <li>{{this.index}}. {{this.name}} ({{this.type}})</li>
                {{/each}}
              </ul>
            {{/if}}
            {{#if journalCreateIntentSummary.notes.length}}
              <h6>Create-Path Notes</h6>
              <ul class="swf-builder-shell__status">
                {{#each journalCreateIntentSummary.notes}}
                  <li>{{this}}</li>
                {{/each}}
              </ul>
            {{/if}}
          </section>
        {{/if}}
        <p>Creates one world JournalEntry from the current Journal preview using minimal v13-safe fields.</p>
        <button
          type="button"
          class="swf-builder-shell__action"
          data-action="create-journal"
          {{#unless journalValidation.ok}}disabled title="Journal creation is blocked until validation errors are resolved."{{/unless}}
        >
          Create Journal Entry
        </button>
      {{/if}}
      {{#if selectedJournalPreset}}
        {{#if journalCreateInspection}}
          <section class="swf-builder-shell__inspection">
            <h5>Journal Pipeline Stage: Post-Creation Inspection</h5>
            <p
              class="swf-builder-shell__status-note swf-builder-shell__status-note--{{#if journalCreateInspection.status.ok}}success{{else}}error{{/if}}"
            >
              <strong>{{journalCreateInspection.status.label}}:</strong>
              {{journalCreateInspection.status.message}}
            </p>

            {{#if journalCreateInspection.createdJournal}}
              <ul class="swf-builder-shell__status">
                <li>Name: {{journalCreateInspection.createdJournal.name}}</li>
                <li>ID: <code>{{journalCreateInspection.createdJournal.id}}</code></li>
                {{#if journalCreateInspection.createdJournal.uuid}}
                  <li>UUID: <code>{{journalCreateInspection.createdJournal.uuid}}</code></li>
                {{/if}}
              </ul>
              {{#if canOpenCreatedJournal}}
                <button type="button" class="swf-builder-shell__action" data-action="open-created-journal">
                  Open Created Journal
                </button>
              {{/if}}
            {{/if}}

            <div class="swf-builder-shell__inspection-grid">
              <section class="swf-builder-shell__inspection-section">
                <h6>Materialized Clusters</h6>
                {{#if journalCreateInspection.materializedClusters.length}}
                  <ul class="swf-builder-shell__status">
                    {{#each journalCreateInspection.materializedClusters}}
                      <li>{{this}}</li>
                    {{/each}}
                  </ul>
                {{else}}
                  <p class="swf-builder-shell__empty">No clusters were materialized in this attempt.</p>
                {{/if}}
              </section>

              <section class="swf-builder-shell__inspection-section">
                <h6>Deferred Clusters</h6>
                <ul class="swf-builder-shell__status">
                  {{#each journalCreateInspection.deferredClusters}}
                    <li>{{this}}</li>
                  {{/each}}
                </ul>
              </section>
            </div>

            <h6>Preview → Created Mapping</h6>
            <ul class="swf-builder-shell__status">
              {{#each journalCreateInspection.fieldMapping}}
                <li>
                  <strong>{{this.key}}</strong>:
                  preview={{this.preview}} |
                  requested={{this.requested}} |
                  actual={{this.actual}}
                </li>
              {{/each}}
            </ul>

            <h6>Warnings &amp; Notes</h6>
            <ul class="swf-builder-shell__status">
              {{#each journalCreateInspection.warnings}}
                <li>{{this}}</li>
              {{/each}}
              {{#each journalCreateInspection.notes}}
                <li>{{this}}</li>
              {{/each}}
            </ul>
            {{#if journalCreateInspection.validation}}
              <h6>Validation Used for Attempt</h6>
              <ul class="swf-builder-shell__status">
                <li>Status: {{journalCreateInspection.validation.label}}</li>
                <li>{{journalCreateInspection.validation.summary}}</li>
                {{#each journalCreateInspection.validation.errors}}
                  <li>Error: {{this}}</li>
                {{/each}}
                {{#each journalCreateInspection.validation.warnings}}
                  <li>Warning: {{this}}</li>
                {{/each}}
              </ul>
            {{/if}}
          </section>
        {{/if}}
      {{/if}}


      <h4>Validation &amp; Trace</h4>
      <ul class="swf-builder-shell__status">
        <li>Readiness: <strong>{{validationTrace.readiness.status}}</strong></li>
        <li>{{validationTrace.readiness.summary}}</li>
      </ul>
      <div class="swf-builder-shell__trace-grid">
        {{#each validationTrace.sections}}
          <section class="swf-builder-shell__trace-section">
            <h5>{{this.label}}</h5>
            {{#if this.hasItems}}
              <ul class="swf-builder-shell__status swf-builder-shell__trace-list" data-trace-section="{{this.key}}">
                {{#each this.items}}
                  <li>{{this}}</li>
                {{/each}}
              </ul>
            {{else}}
              <p class="swf-builder-shell__empty">{{this.emptyText}}</p>
            {{/if}}
          </section>
        {{/each}}
      </div>

      <h4>Materialization Readiness</h4>
      <ul class="swf-builder-shell__status">
        <li>Status: <strong>{{materializationReadiness.readiness.status}}</strong></li>
        <li>{{materializationReadiness.readiness.summary}}</li>
        <li>Next-Step Summary: {{materializationReadiness.nextStepSummary}}</li>
      </ul>
      <div class="swf-builder-shell__readiness-grid">
        {{#each materializationReadiness.sections}}
          <section class="swf-builder-shell__readiness-section">
            <h5>{{this.label}}</h5>
            {{#if this.hasItems}}
              <ul class="swf-builder-shell__status swf-builder-shell__readiness-list" data-readiness-section="{{this.key}}">
                {{#each this.items}}
                  <li>{{this}}</li>
                {{/each}}
              </ul>
            {{else}}
              <p class="swf-builder-shell__empty">{{this.emptyText}}</p>
            {{/if}}
          </section>
        {{/each}}
      </div>
      <p><strong>Next step:</strong> {{materializationReadiness.nextStepNote}}</p>

      {{#if activePreview.preview.roleLabel}}
        <h4>Actor Authoring Structure</h4>
        <ul class="swf-builder-shell__status">
          <li>Role Label: {{activePreview.preview.roleLabel}}</li>
          <li>Concept: {{activePreview.preview.concept}}</li>
        </ul>

        <div class="swf-builder-shell__cluster-grid">
          <section class="swf-builder-shell__cluster">
            <h5>Identity Cluster</h5>
            <ul class="swf-builder-shell__status">
              <li>Ancestry: {{activePreview.preview.identity.ancestry}}</li>
              <li>Alignment: {{activePreview.preview.identity.alignment}}</li>
              <li>Disposition: {{activePreview.preview.identity.disposition}}</li>
            </ul>
          </section>

          <section class="swf-builder-shell__cluster">
            <h5>Classification Cluster</h5>
            <ul class="swf-builder-shell__status">
              <li>Actor Path: {{activePreview.preview.classification.actorPath}}</li>
              <li>Grouping: {{activePreview.preview.classification.grouping}}</li>
              <li>Encounter Role: {{activePreview.preview.classification.encounterRole}}</li>
            </ul>
          </section>
        </div>

        <h5>Preview Metadata</h5>
        <ul class="swf-builder-shell__status">
          <li>Schema: v{{activePreview.preview.previewMeta.schemaVersion}}</li>
          <li>Mode: {{activePreview.preview.previewMeta.mode}}</li>
          <li>Materialization: {{activePreview.preview.previewMeta.materialization}}</li>
        </ul>
        <ul class="swf-builder-shell__status">
          {{#each activePreview.preview.previewMeta.integrationNotes}}
            <li>{{this}}</li>
          {{/each}}
        </ul>
      {{/if}}

      <h4>Linked References (Shared Preview Model)</h4>
      {{#if referenceRows.length}}
        <ul class="swf-builder-shell__reference-list">
          {{#each referenceRows}}
            <li class="swf-builder-shell__reference-row">
              <div class="swf-builder-shell__reference-title">{{this.title}}</div>
              {{#if this.detailText}}
                <div class="swf-builder-shell__reference-detail">{{this.detailText}}</div>
              {{/if}}
            </li>
          {{/each}}
        </ul>
      {{else}}
        <p class="swf-builder-shell__empty">No linked references are defined for this preview.</p>
      {{/if}}

      {{#if journalReferenceBlock}}
        <h4>Journal Structured References</h4>
        <ul class="swf-builder-shell__status">
          <li>Title: {{journalReferenceBlock.title}}</li>
          <li>Status: {{journalReferenceBlock.statusLabel}}</li>
          <li>Target Page: {{journalReferenceBlock.targetPageName}}</li>
          <li>Emphasis Primary Group: {{journalReferenceBlock.emphasis.primaryGroupLabel}}</li>
          <li>Emphasis Secondary Group: {{journalReferenceBlock.emphasis.secondaryGroupLabel}}</li>
          <li>Surfaced Item/Actor References: {{journalReferenceBlock.surfacedCount}}</li>
          <li>Total Deferred References: {{journalReferenceBlock.deferredCount}}</li>
        </ul>
        <p>{{journalReferenceBlock.summary}}</p>
        {{#if journalReferenceBlock.emphasis.note}}
          <p class="swf-builder-shell__status-note">{{journalReferenceBlock.emphasis.note}}</p>
        {{/if}}

        <h5>{{journalReferenceBlock.emphasis.primaryGroupLabel}}</h5>
        {{#if journalReferenceBlock.primarySections.length}}
          {{#each journalReferenceBlock.primarySections}}
            <section class="swf-builder-shell__cluster">
              <h6>{{this.label}} ({{this.count}})</h6>
              {{#if this.count}}
                <ul class="swf-builder-shell__status">
                  {{#each this.entries}}
                    <li>
                      <strong>{{this.label}}</strong>
                      {{#if this.role}} · role={{this.role}}{{/if}}
                      · status={{this.status}}
                      · {{this.note}}
                    </li>
                  {{/each}}
                </ul>
              {{else}}
                <p class="swf-builder-shell__empty">No {{this.kind}} references surfaced.</p>
              {{/if}}
            </section>
          {{/each}}
        {{else}}
          <p class="swf-builder-shell__empty">No primary references surfaced for this preset.</p>
        {{/if}}

        <h5>{{journalReferenceBlock.emphasis.secondaryGroupLabel}}</h5>
        {{#if journalReferenceBlock.secondarySections.length}}
          {{#each journalReferenceBlock.secondarySections}}
            <section class="swf-builder-shell__cluster">
              <h6>{{this.label}} ({{this.count}})</h6>
              {{#if this.count}}
                <ul class="swf-builder-shell__status">
                  {{#each this.entries}}
                    <li>
                      <strong>{{this.label}}</strong>
                      {{#if this.role}} · role={{this.role}}{{/if}}
                      · status={{this.status}}
                      · {{this.note}}
                    </li>
                  {{/each}}
                </ul>
              {{else}}
                <p class="swf-builder-shell__empty">No {{this.kind}} references surfaced.</p>
              {{/if}}
            </section>
          {{/each}}
        {{else}}
          <p class="swf-builder-shell__empty">No secondary references surfaced for this preset.</p>
        {{/if}}

      {{/if}}

      <h4>Notes</h4>
      <ul class="swf-builder-shell__status">
        {{#each activePreview.preview.notes}}
          <li>{{this}}</li>
        {{/each}}
      </ul>

      <h4>Shared Preview Payload</h4>
      <pre class="swf-builder-shell__code">{{activePreviewJson}}</pre>
    </section>
  {{else}}
    <p class="swf-builder-shell__empty">No active preview surface is available.</p>
  {{/if}}

  <h4>Current Assumptions</h4>
  <ul class="swf-builder-shell__status">
    {{#each assumptions}}
      <li>{{this}}</li>
    {{/each}}
  </ul>
</section>
