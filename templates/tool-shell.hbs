<section class="swf-tool-shell__body">
  <p>
    This is a safe placeholder window for future SWF content-tooling slices.
    No game documents are modified from this shell.
  </p>

  <hr />

  <h3>Status</h3>
  <ul class="swf-tool-shell__status">
    <li>Debug Logging: {{#if settings.debugLogging}}On{{else}}Off{{/if}}</li>
    <li>Dev Tools Placeholder: {{#if settings.enableDevTools}}On{{else}}Off{{/if}}</li>
    <li>Future Content Tools: {{#if settings.futureContentToolsEnabled}}On{{else}}Off{{/if}}</li>
    <li>Loaded Valid Manifest Entries: {{manifests.total}}</li>
    <li>Invalid Manifest Entries: {{manifests.invalid}}</li>
  </ul>

  <h3>Mapping Coverage (Read-Only)</h3>
  {{#if mappingCoverage.hasEntries}}
    <ul class="swf-tool-shell__status">
      <li>Types: {{mappingCoverage.summary.manifestTypeCount}}</li>
      <li>Tracked Fields: {{mappingCoverage.summary.totalTrackedFields}}</li>
      <li>Confirmed: {{mappingCoverage.summary.confirmedCount}}</li>
      <li>Provisional: {{mappingCoverage.summary.provisionalCount}}</li>
      <li>Unresolved: {{mappingCoverage.summary.unresolvedCount}}</li>
      <li>Planned: {{mappingCoverage.summary.plannedCount}}</li>
      <li>Unmapped: {{mappingCoverage.summary.unmappedCount}}</li>
    </ul>
    <ul class="swf-tool-shell__manifest-list">
      {{#each mappingCoverage.entries}}
        <li>
          <div><strong>{{this.manifestType}}</strong> · Tracked: {{this.totalTrackedFields}}</div>
          <div class="swf-tool-shell__manifest-meta">
            <span>Confirmed: {{this.confirmedCount}}</span>
            <span>Provisional: {{this.provisionalCount}}</span>
            <span>Unresolved: {{this.unresolvedCount}}</span>
            <span>Planned: {{this.plannedCount}}</span>
            <span>Unmapped: {{this.unmappedCount}}</span>
          </div>
          <div class="swf-tool-shell__hint">{{this.coverageNotes}}</div>
        </li>
      {{/each}}
    </ul>
  {{else}}
    <p class="swf-tool-shell__empty">No mapping coverage data is available yet.</p>
  {{/if}}


  <h3>Shape Consistency (Read-Only)</h3>
  {{#if shapeConsistency.hasEntries}}
    <ul class="swf-tool-shell__status">
      <li>Types: {{shapeConsistency.summary.totalTypes}}</li>
      <li>Consistent: {{shapeConsistency.summary.consistentCount}}</li>
      <li>Drift: {{shapeConsistency.summary.driftCount}}</li>
      <li>Warning: {{shapeConsistency.summary.warningCount}}</li>
    </ul>
    <ul class="swf-tool-shell__manifest-list">
      {{#each shapeConsistency.statuses}}
        <li><strong>{{this.manifestType}}</strong> · <span>Status: {{this.status}}</span></li>
      {{/each}}
    </ul>
  {{else}}
    <p class="swf-tool-shell__empty">No shape-consistency data is available yet.</p>
  {{/if}}

  <h3>Manifest Browser (Read-Only)</h3>
  <p class="swf-tool-shell__hint">Showing module-owned manifest metadata from the in-memory registry.</p>

  <ul class="swf-tool-shell__status">
    <li>Manifest Files Checked: {{manifests.attempted}}</li>
    <li>Load Failures: {{manifests.failed}}</li>
  </ul>

  {{#if manifests.hasFailures}}
    <p class="swf-tool-shell__warning">Some manifests were skipped during validation. See console logs for details.</p>
  {{/if}}

  {{#if manifests.hasEntries}}
    <ul class="swf-tool-shell__manifest-list">
      {{#each manifests.entries}}
        <li>
          <strong>{{this.name}}</strong>
          <button type="button" class="swf-tool-shell__view-button {{#if this.isSelected}}is-selected{{/if}}" data-manifest-key="{{this.selectionKey}}">
            {{#if this.isSelected}}Viewing{{else}}View{{/if}}
          </button>
          <div class="swf-tool-shell__manifest-meta">
            <span>ID: <code>{{this.id}}</code></span>
            <span>Type: {{this.type}}</span>
            <span>Version: {{this.version}}</span>
            <span>Status: {{this.status}}</span>
            <span>Example: {{#if this.isCanonicalExample}}canonical{{else}}no{{/if}}</span>
            <span>Validation: {{this.validationState}}</span>
          </div>
        </li>
      {{/each}}
    </ul>
  {{else}}
    <p class="swf-tool-shell__empty">No module manifests are currently loaded.</p>
  {{/if}}

  {{#if manifests.hasInvalidEntries}}
    <h3>Invalid Manifests (Read-Only)</h3>
    <ul class="swf-tool-shell__manifest-list">
      {{#each manifests.invalidEntries}}
        <li>
          <strong>{{this.id}}</strong>
          <button type="button" class="swf-tool-shell__view-button {{#if this.isSelected}}is-selected{{/if}}" data-manifest-key="{{this.selectionKey}}">
            {{#if this.isSelected}}Viewing{{else}}View{{/if}}
          </button>
          <div class="swf-tool-shell__manifest-meta">
            <span>Type: {{this.type}}</span>
            <span>Issues: {{this.issueCount}}</span>
          </div>
          <p class="swf-tool-shell__hint">{{this.issueSummary}}</p>
        </li>
      {{/each}}
    </ul>
  {{/if}}

  <h3>Manifest Detail (Read-Only)</h3>
  {{#if manifests.detail.hasSelection}}
    <ul class="swf-tool-shell__status">
      <li>Source: {{manifests.detail.source}}</li>
      {{#if manifests.detail.path}}<li>Path: <code>{{manifests.detail.path}}</code></li>{{/if}}
      <li>ID: <code>{{manifests.detail.id}}</code></li>
      <li>Type: {{manifests.detail.type}}</li>
      <li>Name: {{manifests.detail.name}}</li>
      <li>Version: {{manifests.detail.version}}</li>
      <li>Status: {{manifests.detail.status}}</li>
      <li>Example: {{#if manifests.detail.isCanonicalExample}}canonical{{else}}no{{/if}}</li>
      <li>Description: {{manifests.detail.description}}</li>
      <li>Validation: {{manifests.detail.validationSummary}}</li>
    </ul>

    {{#if manifests.detail.hasTypeSpecificFields}}
      <h4>Type-Specific Fields</h4>
      <ul class="swf-tool-shell__status">
        {{#each manifests.detail.typeSpecificFields}}
          <li>{{this.key}}: {{this.value}}</li>
        {{/each}}
      </ul>
    {{/if}}

    {{#if manifests.detail.hasCanonicalFields}}
      <h4>Canonical Field Inventory (Read-Only)</h4>
      <ul class="swf-tool-shell__manifest-list">
        {{#each manifests.detail.canonicalFields}}
          <li>
            <div><strong><code>{{this.field}}</code></strong> · <span>{{this.category}}</span></div>
            <div class="swf-tool-shell__manifest-meta">
              <span>Required: {{#if this.required}}yes{{else}}no{{/if}}</span>
            </div>
            {{#if this.notes}}<div class="swf-tool-shell__hint">{{this.notes}}</div>{{/if}}
          </li>
        {{/each}}
      </ul>
    {{/if}}


    {{#if manifests.detail.hasIntendedTarget}}
      <h4>Intended Target (Read-Only)</h4>
      <ul class="swf-tool-shell__status">
        <li>Manifest Type: {{manifests.detail.intendedTarget.manifestType}}</li>
        <li>Foundry Document Type: {{manifests.detail.intendedTarget.foundryDocumentType}}</li>
        <li>dnd5e Subtype: {{manifests.detail.intendedTarget.dnd5eDocumentSubtype}}</li>
        <li>Intended Compendium Kind: {{manifests.detail.intendedTarget.intendedCompendiumKind}}</li>
      </ul>
      <ul class="swf-tool-shell__manifest-list">
        {{#each manifests.detail.intendedTarget.notes}}
          <li class="swf-tool-shell__hint">{{this}}</li>
        {{/each}}
      </ul>
    {{/if}}


    {{#if manifests.detail.hasFieldMappingNotes}}
      <h4>Field Mapping Notes (Read-Only)</h4>
      <ul class="swf-tool-shell__manifest-list">
        {{#each manifests.detail.fieldMappingNotes}}
          <li>
            <div><strong><code>{{this.manifestField}}</code></strong> → <code>{{this.intendedTargetPath}}</code></div>
            <div class="swf-tool-shell__manifest-meta">
              <span>Target: {{this.targetDocumentType}}</span>
              <span>Status: {{this.status}}</span>
            </div>
            <div class="swf-tool-shell__hint">{{this.notes}}</div>
          </li>
        {{/each}}
      </ul>
    {{/if}}

    {{#if manifests.detail.hasUnresolvedMappings}}
      <h4>Unresolved Mapping Notes (Read-Only)</h4>
      <ul class="swf-tool-shell__status">
        <li>Unresolved: {{manifests.detail.unresolvedMappingStatusCounts.unresolved}}</li>
        <li>Provisional: {{manifests.detail.unresolvedMappingStatusCounts.provisional}}</li>
        <li>Blocked: {{manifests.detail.unresolvedMappingStatusCounts.blocked}}</li>
        <li>Confirmed: {{manifests.detail.unresolvedMappingStatusCounts.confirmed}}</li>
      </ul>
      <ul class="swf-tool-shell__manifest-list">
        {{#each manifests.detail.unresolvedMappings}}
          <li>
            <div><strong><code>{{this.field}}</code></strong> · <span>Status: {{this.status}}</span></div>
            <div class="swf-tool-shell__hint">{{this.unresolvedReason}}</div>
            <div class="swf-tool-shell__hint">Next check: {{this.suggestedNextCheck}}</div>
            <div class="swf-tool-shell__hint">{{this.notes}}</div>
          </li>
        {{/each}}
      </ul>
    {{/if}}

    {{#if manifests.detail.hasConfirmedMappings}}
      <h4>Confirmed Mapping Snapshot (Read-Only)</h4>
      <ul class="swf-tool-shell__status">
        <li>Confirmed: {{manifests.detail.confirmedMappingStatusCounts.confirmed}}</li>
        <li>Provisional: {{manifests.detail.confirmedMappingStatusCounts.provisional}}</li>
        <li>Unresolved: {{manifests.detail.confirmedMappingStatusCounts.unresolved}}</li>
        <li>Planned: {{manifests.detail.confirmedMappingStatusCounts.planned}}</li>
        <li>Confirmed Coverage: {{manifests.detail.confirmedMappingCoverage.confirmedFields}} / {{manifests.detail.confirmedMappingCoverage.totalTrackedFields}}</li>
      </ul>
      <ul class="swf-tool-shell__manifest-list">
        {{#each manifests.detail.confirmedMappings}}
          <li>
            <div><strong><code>{{this.field}}</code></strong> · <span>Status: {{this.status}}</span></div>
            <div class="swf-tool-shell__hint">Path: <code>{{this.confirmedTargetPath}}</code></div>
            <div class="swf-tool-shell__hint">Source: {{this.confirmedSource}}</div>
            <div class="swf-tool-shell__hint">{{this.confirmedTargetNote}}</div>
            <div class="swf-tool-shell__hint">{{this.notes}}</div>
          </li>
        {{/each}}
      </ul>
    {{/if}}

    {{#if manifests.detail.hasFeatTargetStub}}
      <h4>Intended Feat Item Stub (Read-Only)</h4>
      <p class="swf-tool-shell__hint">{{manifests.detail.featTargetStubSummary}}</p>
      <p class="swf-tool-shell__hint">Presentation Cluster: {{manifests.detail.featPresentationSummary}}</p>
      <p class="swf-tool-shell__hint">Prerequisites Cluster: {{manifests.detail.featPrerequisitesSummary}}</p>
      {{#if manifests.detail.featPrerequisitesCluster}}
        <ul class="swf-tool-shell__status">
          <li>Requirements Text: {{manifests.detail.featTargetStub.system.requirements}}</li>
          <li>Minimum Level: {{manifests.detail.featPrerequisitesCluster.level}}</li>
        </ul>
      {{/if}}
      <p class="swf-tool-shell__hint">Intentionally omitted unresolved targets: {{manifests.detail.featTargetStubOmittedCount}}</p>
      <pre class="swf-tool-shell__hint"><code>{{manifests.detail.featTargetStubJson}}</code></pre>
    {{/if}}

    {{#if manifests.detail.hasFeatConversionTrace}}
      <h4>Feat Conversion Trace (Read-Only)</h4>
      <p class="swf-tool-shell__hint">{{manifests.detail.featConversionTraceSummary}}</p>
      <ul class="swf-tool-shell__manifest-list">
        {{#each manifests.detail.featConversionTrace}}
          <li>
            <div><strong><code>{{this.manifestField}}</code></strong> → <code>{{this.targetPath}}</code></div>
            <div class="swf-tool-shell__manifest-meta">
              <span>Status: {{this.status}}</span>
              <span>Source: {{this.sourceValue}}</span>
              <span>Target: {{this.targetValue}}</span>
            </div>
            <div class="swf-tool-shell__hint">{{this.notes}}</div>
          </li>
        {{/each}}
      </ul>
    {{/if}}

    {{#if manifests.detail.hasFeatConversionTraceDiagnostics}}
      <h4>Feat Conversion Trace Diagnostics</h4>
      <ul class="swf-tool-shell__manifest-list">
        {{#each manifests.detail.featConversionTraceDiagnostics}}
          <li>
            <span><strong><code>{{this.code}}</code></strong>{{#if this.field}} · field: <code>{{this.field}}</code>{{/if}}</span>
            <div class="swf-tool-shell__hint">{{this.message}}</div>
          </li>
        {{/each}}
      </ul>
    {{/if}}

    {{#if manifests.detail.hasFeatTargetDiagnostics}}
      <h4>Feat Stub Diagnostics</h4>
      <ul class="swf-tool-shell__manifest-list">
        {{#each manifests.detail.featTargetDiagnostics}}
          <li>
            <span><strong><code>{{this.code}}</code></strong>{{#if this.field}} · field: <code>{{this.field}}</code>{{/if}}</span>
            <div class="swf-tool-shell__hint">{{this.message}}</div>
          </li>
        {{/each}}
      </ul>
    {{/if}}

    {{#if manifests.detail.hasIssues}}
      <h4>Validation Issues</h4>
      <ul class="swf-tool-shell__manifest-list">
        {{#each manifests.detail.issues}}
          <li>
            <span><strong>{{this.severity}}</strong> · <code>{{this.code}}</code>{{#if this.field}} · field: <code>{{this.field}}</code>{{/if}}</span>
            <div class="swf-tool-shell__hint">{{this.message}}</div>
          </li>
        {{/each}}
      </ul>
    {{/if}}
  {{else}}
    <p class="swf-tool-shell__empty">Select a manifest from the lists above to inspect normalized fields and validation details.</p>
  {{/if}}
</section>
