<section class="swf-tool-shell__body">
  <p>
    This is a safe placeholder window for future SWF content-tooling slices.
    No game documents are modified from this shell.
  </p>

  <hr />

  <h3>Status</h3>
  <ul class="swf-tool-shell__status">
    <li>Debug Logging: {{#if settings.debugLogging}}On{{else}}Off{{/if}}</li>
    <li>Dev Tools Placeholder: {{#if settings.enableDevTools}}On{{else}}Off{{/if}}</li>
    <li>Future Content Tools: {{#if settings.futureContentToolsEnabled}}On{{else}}Off{{/if}}</li>
    <li>Loaded Valid Manifest Entries: {{manifests.total}}</li>
    <li>Invalid Manifest Entries: {{manifests.invalid}}</li>
  </ul>

  <h3>Manifest Browser (Read-Only)</h3>
  <p class="swf-tool-shell__hint">Showing module-owned manifest metadata from the in-memory registry.</p>

  <ul class="swf-tool-shell__status">
    <li>Manifest Files Checked: {{manifests.attempted}}</li>
    <li>Load Failures: {{manifests.failed}}</li>
  </ul>

  {{#if manifests.hasFailures}}
    <p class="swf-tool-shell__warning">Some manifests were skipped during validation. See console logs for details.</p>
  {{/if}}

  {{#if manifests.hasEntries}}
    <ul class="swf-tool-shell__manifest-list">
      {{#each manifests.entries}}
        <li>
          <strong>{{this.name}}</strong>
          <div class="swf-tool-shell__manifest-meta">
            <span>ID: <code>{{this.id}}</code></span>
            <span>Type: {{this.type}}</span>
            <span>Version: {{this.version}}</span>
            <span>Status: {{this.status}}</span>
            <span>Validation: {{this.validationState}}</span>
          </div>
        </li>
      {{/each}}
    </ul>
  {{else}}
    <p class="swf-tool-shell__empty">No module manifests are currently loaded.</p>
  {{/if}}

  {{#if manifests.hasInvalidEntries}}
    <h3>Invalid Manifests (Read-Only)</h3>
    <ul class="swf-tool-shell__manifest-list">
      {{#each manifests.invalidEntries}}
        <li>
          <strong>{{this.id}}</strong>
          <div class="swf-tool-shell__manifest-meta">
            <span>Type: {{this.type}}</span>
            <span>Issues: {{this.issueCount}}</span>
          </div>
          <p class="swf-tool-shell__hint">{{this.issueSummary}}</p>
        </li>
      {{/each}}
    </ul>
  {{/if}}
</section>
